{
  "manifest_version": 3,
  "name": "ReadAble: Dyslexia Font & Reading Tools",
  "description": "Make websites easier to read with OpenDyslexic, a reading ruler, spacing controls, larger text, and high contrast.",
  "version": "1.4.0",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "index.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/OpenDyslexic/compiled/OpenDyslexic-Regular.woff2",
        "fonts/OpenDyslexic/compiled/OpenDyslexic-Bold.woff2",
        "fonts/OpenDyslexic/compiled/OpenDyslexic-Italic.woff2",
        "fonts/OpenDyslexic/compiled/OpenDyslexic-Bold-Italic.woff2"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
        
}
